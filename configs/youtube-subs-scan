#!/bin/sh
# Scan YouTube subscriptions (requires logged-in cookies) and cache channel names + URLs.
# Default cookies source: Firefox (override with YT_COOKIES_BROWSER=chromium|chrome|firefox|...)
# Cache: ~/.cache/yt-subs.auto.txt (or $XDG_CACHE_HOME)
# Format per line: channel_name|||https://www.youtube.com/channel/UC...

set -u

BROWSER="${YT_COOKIES_BROWSER:-firefox}"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
CACHE_FILE="${YT_SUBS_AUTO_CACHE:-$CACHE_DIR/yt-subs.auto.txt}"

mkdir -p "$CACHE_DIR" || exit 1
tmp="${CACHE_FILE}.tmp.$$"

yt-dlp --cookies-from-browser "$BROWSER" --flat-playlist \
  --print "%(channel)s|||%(channel_id)s" \
  "https://www.youtube.com/feed/channels" 2>/dev/null \
| awk -F'\\|\\|\\|' '
  NF>=2 && $1!="" && $2 ~ /^UC[0-9A-Za-z_-]+$/ {
    gsub(/[[:space:]]+$/, "", $1)
    print $1 "|||https://www.youtube.com/channel/" $2
  }
' \
| awk '!seen[$0]++' \
> "$tmp" || true

if [ -s "$tmp" ]; then
  {
    printf "# Auto-generated by youtube-subs-scan on %s\n" "$(date -Is 2>/dev/null || date)"
    cat "$tmp"
  } > "${tmp}.hdr" && mv -f "${tmp}.hdr" "$CACHE_FILE"
  rm -f "$tmp"
  exit 0
fi

rm -f "$tmp" "${tmp}.hdr"
exit 1

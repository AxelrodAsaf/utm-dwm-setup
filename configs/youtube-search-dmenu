#!/bin/sh
# YouTube search via dmenu, aligned columns (Channel | Duration | Title | id)
# BACK is shown under the query textbox; selecting it returns to youtube-dmenu.

set -u

: "${MAX_RESULTS:=30}"
: "${MAX_TITLE:=80}"

DMENU_QUERY="${DMENU_QUERY:-dmenu -i -l 8 -p 'YouTube Search:'}"
DMENU_RESULTS="${DMENU_RESULTS:-dmenu -i -l 20 -p 'YouTube Results:'}"

cache="${XDG_CACHE_HOME:-$HOME/.cache}"
mkdir -p "$cache" || exit 1

tmpdir="$(mktemp -d "$cache/youtube-search.XXXXXX")" || exit 1
raw="$tmpdir/raw"
menu="$tmpdir/menu"
trap 'rm -rf "$tmpdir"' EXIT INT HUP TERM

while :; do
  # Query prompt with BACK row shown in list
  QUERY="$(printf '%s\n' "<-- BACK" | sh -c "$DMENU_QUERY")" || exit 0
  [ -n "${QUERY:-}" ] || exit 0
  [ "$QUERY" = "<-- BACK" ] && exit 0

  # Raw record format:
  # channel|||duration_string|||title|||id
  yt-dlp --flat-playlist "ytsearch${MAX_RESULTS}:$QUERY" 2>/dev/null \
    --replace-in-metadata title '[\r\n\t]+' ' ' \
    --print "%(uploader)s|||%(duration_string)s|||%(title)s|||%(id)s" \
  | awk -F'\\|\\|\\|' 'NF>=4 && $1!="" && $4!="" { print }' \
  > "$raw" || true

  [ -s "$raw" ] || continue

  max_chan="$(awk -F'\\|\\|\\|' '{ if(length($1)>m) m=length($1) } END{ print (m?m:7) }' "$raw")"
  max_title="$(awk -F'\\|\\|\\|' -v cap="$MAX_TITLE" '{ if(length($3)>m) m=length($3) } END{ if(!m)m=20; if(m>cap)m=cap; print m }' "$raw")"

  awk -F'\\|\\|\\|' -v mc="$max_chan" -v mt="$max_title" '
  function z2(x){ return (length(x)<2 ? "0"x : x) }
  function fmt(d, a,n){
    if(d=="" || d=="NA") return "??:??"
    n=split(d,a,":")
    if(n==2) return z2(a[1]) ":" z2(a[2])
    if(n==3) return z2(a[1]) ":" z2(a[2]) ":" z2(a[3])
    return d
  }
  function trunc(s, n){ return (length(s)>n ? substr(s,1,n-1) "…" : s) }
  BEGIN {
    printf "%-*s | %8s | %-*s | %s\n", mc, "<-- BACK", "", mt, "Return to query", "__BACK__"
  }
  {
    chan=$1
    dur=fmt($2)
    title=trunc($3, mt)
    id=$4
    printf "%-*s | %8s | %-*s | %s\n", mc, chan, dur, mt, title, id
  }
  ' "$raw" >"$menu"

  CHOICE="$(cat "$menu" | sh -c "$DMENU_RESULTS")" || continue
  VID="$(printf '%s' "$CHOICE" | awk -F' \\| ' '{print $NF}')"
  [ -n "${VID:-}" ] || continue
  [ "$VID" = "__BACK__" ] && continue

  exec mpv --ytdl=yes "https://youtu.be/$VID"
done
